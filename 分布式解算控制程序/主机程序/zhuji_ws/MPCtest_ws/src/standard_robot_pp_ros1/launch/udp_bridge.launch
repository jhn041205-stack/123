<launch>
  <arg name="config_file" default="$(find standard_robot_pp_ros1)/config/real_vehicle_comm.yaml" />
  <rosparam command="load" file="$(arg config_file)" />

  <node pkg="standard_robot_pp_ros1"
        type="imu_udp_sender_node"
        name="imu_udp_sender_node"
        output="screen" />

  <node pkg="standard_robot_pp_ros1"
        type="udp_command_receiver_node"
        name="udp_command_receiver_node"
        output="screen" />
</launch>
